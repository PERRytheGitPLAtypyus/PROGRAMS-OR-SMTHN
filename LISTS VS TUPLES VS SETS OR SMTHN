#tuple is represented by () and is immutable not appendable
t = (1, 2, 3, 4, 5)
t=t+(100,56) #we can concatenate two tuples but we cannot change the existing tuple and supports indexing and slicing
print(t)
#set is represented by {} and is mutable but it is unordered and does not allow duplicates and also does not support indexing
b=[1,4,1,2,2,3,3,4,5]
s=set(b)
print(s)
c={1,4,1,2,2,3,3,4,5}
for i in c:
    print("hello")
d={1,2,3,4,5}
e=[1,2,3,4,5]
f=(1,2,3,4,5)
print(type(d))
print(type(e))
print(type(f))
d.add(6) #we can add elements to a set but not to a tuple
print(d)
g={12,13,14,15,16}
h={1,13,24,16,18}
print(g.intersection(h)) #intersection of two sets
print(g.union(h)) #union of two sets
print(g|h) #union of two sets
print(g&h) #intersection of two sets
print(g^h) #symmetric difference of two sets
print(g.symmetric_difference(h)) #symmetric difference of two sets
print(g-h) #difference of two sets
print(h-g) #difference of two sets
print(g.difference(h)) #difference of two sets  
print(h.difference(g)) #difference of two sets  
print(g.issubset(h)) #check if g is subset of h
print(h.issubset(g)) #check if h is subset of g
print(g.issuperset(h)) #check if g is superset of h 
print(h.issuperset(g)) #check if h is superset of g


